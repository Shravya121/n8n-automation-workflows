    {
      "parameters": {
        "jsCode": "const { text, chatId, firstName } = items[0].json;\nconst raw = (text || '').trim();\n\nif (!raw || raw.toUpperCase() === 'UNCLEAR') {\n  return [{ json: {\n    valid: false, chatId,\n    errorMsg: \"Couldn't read the expense. Try: '250 food lunch'\"\n  }}];\n}\n\nconst response = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://api.groq.com/openai/v1/chat/completions',\n  headers: {\n    'Authorization': `Bearer your_api_key`,\n    'Content-Type': 'application/json'\n  },\n  body: {\n    model: 'llama-3.3-70b-versatile',\n    max_tokens: 100,\n    messages: [\n      {\n        role: 'system',\n       content: `You are an expense parser. Extract the numeric amount, category and description from any natural language message.\nEven if the message is informal like \"Today's expenses 300\" or \"chai 20\" or \"spent 150 uber\", extract the number as amount.\nCategory must be one of: food, transport, shopping, health, utilities, entertainment, other. Guess the best category.\nReply ONLY in this exact format with pipe separators: amount|category|description\nExample: 250|food|lunch at MTR\nOnly reply UNCLEAR if there is absolutely no number in the message.`\n      },\n      { role: 'user', content: raw }\n    ]\n  },\n  json: true\n});\n\nconst result = response.choices?.[0]?.message?.content?.trim();\n\nif (!result || result === 'UNCLEAR') {\n  return [{ json: {\n    valid: false, chatId,\n    errorMsg: `Couldn't understand: \"${raw}\"\\n\\nTry: \"250 food lunch\"`\n  }}];\n}\n\nconst parts = result.split('|');\nconst amount = parseFloat(parts[0]);\nconst category = (parts[1] || 'other').toLowerCase().trim();\nconst description = (parts[2] || '').trim();\nconst date = new Date().toISOString().split('T')[0];\n\nif (isNaN(amount) || amount <= 0) {\n  return [{ json: {\n    valid: false, chatId,\n    errorMsg: `Couldn't find an amount in: \"${raw}\"`\n  }}];\n}\n\nreturn [{ json: {\n  valid: true, chatId, firstName,\n  amount, category, description, date\n}}];"
      },
