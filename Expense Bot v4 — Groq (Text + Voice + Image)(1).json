    {
      "parameters": {
        "jsCode": "const item = items[0];\nconst chatId = item.json.chatId;\nconst firstName = item.json.firstName;\nconst filePath = item.json.filePath;\n\nconst imageUrl = `https://api.telegram.org/file/bot8673699203:AAEPsuf5W25QotjcxfXjWpeURnnTcvng7N8/${filePath}`;\n\nconst response = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://api.groq.com/openai/v1/chat/completions',\n  headers: {\n    'Authorization': 'Bearer your_api_key',\n    'Content-Type': 'application/json'\n  },\n  body: {\n    model: 'meta-llama/llama-4-scout-17b-16e-instruct',\n    max_tokens: 100,\n    messages: [\n      {\n        role: 'user',\n        content: [\n          {\n            type: 'image_url',\n            image_url: {\n              url: imageUrl\n            }\n          },\n          {\n            type: 'text',\n            text: 'Extract the total amount from this receipt. Reply ONLY in this format: amount category description. Example: 245.00 food dinner. Category must be one word: food/transport/shopping/health/utilities/other. If no amount visible reply: UNCLEAR'\n          }\n        ]\n      }\n    ]\n  },\n  json: true\n});\n\nconst result = response.choices?.[0]?.message?.content?.trim() || 'UNCLEAR';\n\nreturn [{ json: {\n  text: result,\n  chatId,\n  firstName\n} }];"
      },
