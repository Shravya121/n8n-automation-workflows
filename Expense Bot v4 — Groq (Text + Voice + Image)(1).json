    {
      "parameters": {
        "functionCode": "const { userId, rows } = items[0].json;\nif (!rows || rows.length === 0) return [];\nconst icons = { food:'🍽', transport:'🚗', shopping:'🛍', entertainment:'🎬', health:'💊', utilities:'💡', other:'📦' };\nconst byCategory = {};\nlet total = 0;\nfor (const row of rows) {\n  const cat = (row.Category || 'other').toLowerCase();\n  const amt = parseFloat(row.Amount) || 0;\n  byCategory[cat] = (byCategory[cat] || 0) + amt;\n  total += amt;\n}\nconst lines = Object.entries(byCategory).sort((a,b)=>b[1]-a[1]).map(([cat,amt])=>`${icons[cat]||'📦'} ${cat}: ₹${amt.toFixed(2)}`);\nconst dateStr = new Date().toLocaleDateString('en-IN', { weekday:'long', day:'numeric', month:'long' });\nconst message = [`📊 *Daily Summary — ${dateStr}*`,'', ...lines,'',`💰 *Total: ₹${total.toFixed(2)}*`,`_${rows.length} expense${rows.length!==1?'s':''}_`].join('\\n');\nreturn [{ json: { chatId: userId, message } }];"
      },
      "name": "Build Summary",
      "type": "n8n-nodes-base.function",
